<meta charset="utf-8">
<title>{{title}} | Rosehill College</title>
<meta name="description" content="{{metaDescription}}">
{{#if noindex}}<meta name="robots" content="noindex,follow">{{/if}}
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta property="og:title" content="{{title}} | Rosehill College">
<meta property="og:description" content="{{metaDescription}}">
<meta property="og:type" content="website">
{{#if site.baseUrl}}<link rel="canonical" href="{{site.baseUrl}}{{canonicalPath}}">
<meta property="og:url" content="{{site.baseUrl}}{{canonicalPath}}">{{/if}}
<link rel="icon" href="/assets/img/favicon.png">
<link rel="apple-touch-icon" href="/assets/img/webclip.png">
<link rel="preload" href="/assets/fonts/albertus-nova.woff2" as="font" type="font/woff2" crossorigin>
<link rel="preload" href="/assets/fonts/carlito-400.woff2" as="font" type="font/woff2" crossorigin>
<script>document.documentElement.classList.replace('no-js','js');
if (!matchMedia('(prefers-reduced-motion: reduce)').matches) document.documentElement.classList.add('motion-ok');</script>
