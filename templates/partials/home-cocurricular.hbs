<section class="band band--lg home-cocurricular" id="cocurricular" data-home-cocurricular>
  <div class="container">
    {{> section-head}}
  </div>
  <div class="montage" data-montage>
    {{#each rows}}
    <div class="montage__row" data-montage-row data-dir="{{#if (eq (mod @index 2) 0)}}left{{else}}right{{/if}}">
      {{#each images}}
      <figure class="montage__item media-frame media-frame--card">
        {{! items are min(24rem, 66vw) — match that rather than a guessed vw }}
        <img src="/{{src}}" {{#if srcset}}srcset="{{srcset}}" sizes="(max-width: 36rem) 66vw, 24rem"{{/if}} alt="{{alt}}" loading="lazy" decoding="async">
        <figcaption class="montage__label">{{label}}</figcaption>
      </figure>
      {{/each}}
    </div>
    {{/each}}
  </div>
  <div class="container">
    <div class="band__actions band__actions--center" data-reveal>
      {{#each actions}}<a class="btn {{#if primary}}btn--red{{else}}btn--ghost{{/if}}" href="{{href}}">{{label}}</a>{{/each}}
    </div>
  </div>
</section>
