<section class="band {{#if pad}}band--{{pad}}{{/if}}" {{#if id}}id="{{id}}"{{/if}} {{#if theme}}data-theme="{{theme}}"{{/if}}>
  <div class="container">
    {{> section-head}}
    <div class="accordion col-narrow" data-reveal>
      {{#each items}}
      {{! shared name makes the group exclusive — opening one closes the others
          (native, no JS). Scoped to this section by its id so multiple accordions
          on a page don't fight. }}
      <details class="accordion__item" name="acc-{{#if ../id}}{{../id}}{{else}}group{{/if}}" {{#if open}}open{{/if}}>
        <summary class="accordion__summary">
          <span>{{title}}</span>
          <svg class="accordion__icon" width="14" height="14" viewBox="0 0 512 512" aria-hidden="true"><path fill="currentColor" d="M233.4 406.6c12.5 12.5 32.8 12.5 45.3 0l192-192c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0L256 338.7 86.6 169.4c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3l192 192z"/></svg>
        </summary>
        <div class="accordion__body prose">{{raw html}}</div>
      </details>
      {{/each}}
    </div>
  </div>
</section>
